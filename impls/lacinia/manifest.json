{
  "manifestVersion": 1,
  "name": "lacinia",
  "displayName": "lacinia",
  "homepage": "https://github.com/walmartlabs/lacinia",
  "image": {
    "build": {
      "dockerfile": "./Dockerfile",
      "context": "."
    }
  },
  "runtime": {
    "port": 8080,
    "healthPath": "/health",
    "executePath": "/execute",
    "readinessTimeoutMs": 60000,
    "requestTimeoutMs": 30000
  }
}
