{
  "manifestVersion": 1,
  "name": "graphql-go",
  "displayName": "graphql-go",
  "homepage": "https://github.com/graphql-go/graphql",
  "versionUrlTemplate": "https://github.com/graphql-go/graphql/releases/tag/v{version}",
  "image": {
    "build": {
      "dockerfile": "./Dockerfile",
      "context": "."
    }
  },
  "runtime": {
    "port": 8080,
    "healthPath": "/health",
    "executePath": "/execute",
    "readinessTimeoutMs": 30000,
    "requestTimeoutMs": 30000
  }
}
