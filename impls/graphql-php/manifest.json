{
  "manifestVersion": 1,
  "name": "graphql-php",
  "displayName": "graphql-php (webonyx)",
  "homepage": "https://github.com/webonyx/graphql-php",
  "versionUrlTemplate": "https://github.com/webonyx/graphql-php/releases/tag/v{version}",
  "image": {
    "build": {
      "dockerfile": "./Dockerfile",
      "context": "."
    }
  },
  "runtime": {
    "port": 8080,
    "healthPath": "/health",
    "executePath": "/execute",
    "readinessTimeoutMs": 30000,
    "requestTimeoutMs": 30000
  }
}
