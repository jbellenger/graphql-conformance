{
  "manifestVersion": 1,
  "name": "graphql-core",
  "displayName": "graphql-core (Python)",
  "homepage": "https://github.com/graphql-python/graphql-core",
  "image": {
    "build": {
      "dockerfile": "./Dockerfile",
      "context": "."
    }
  },
  "runtime": {
    "port": 8080,
    "healthPath": "/health",
    "executePath": "/execute",
    "readinessTimeoutMs": 30000,
    "requestTimeoutMs": 30000
  }
}
