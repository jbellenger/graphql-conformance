{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":automergeAll"
  ],
  "automerge": true,
  "schedule": ["before 6am"],
  "timezone": "America/Los_Angeles",
  "packageRules": [
    {
      "description": "graphql-js-17 tracks the npm `alpha` dist-tag (17.x pre-release line)",
      "matchFileNames": ["impls/graphql-js-17/package.json"],
      "matchPackageNames": ["graphql"],
      "followTag": "alpha"
    },
    {
      "description": "graphql-js-16 stays on the 16.x stable line",
      "matchFileNames": ["impls/graphql-js-16/package.json"],
      "matchPackageNames": ["graphql"],
      "allowedVersions": "<17"
    }
  ]
}
